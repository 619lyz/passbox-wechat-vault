page {
  min-height: 100vh;
  background: #f3f5f8;
  color: #17202c;
}

.page {
  min-height: 100vh;
  padding: 40rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  padding: 26rpx 0 34rpx;
  text-align: center;
}

.shield {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  border-radius: 8rpx;
  background: #17202c;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
  box-shadow: 0 18rpx 38rpx rgba(23, 32, 44, 0.18);
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.subtitle {
  width: 580rpx;
  max-width: 100%;
  margin: 14rpx auto 0;
  color: #6f7b8c;
  font-size: 26rpx;
  line-height: 1.6;
}

.status-card,
.sync-card,
.section {
  border: 1rpx solid rgba(211, 218, 229, 0.9);
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(31, 42, 55, 0.06);
}

.status-card {
  display: grid;
  grid-template-columns: 1fr 1rpx 1.4fr;
  align-items: center;
  min-height: 150rpx;
  margin-bottom: 24rpx;
  padding: 26rpx;
  box-sizing: border-box;
}

.sync-card {
  min-height: 118rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 26rpx;
}

.sync-title {
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.sync-text {
  margin-top: 8rpx;
  color: #6f7b8c;
  font-size: 24rpx;
  line-height: 1.4;
}

.sync-error {
  margin-top: 8rpx;
  color: #d93025;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-word;
}

.sync-badge {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  border-radius: 8rpx;
  background: #edf4ff;
  color: #2f77ff;
  font-size: 23rpx;
  font-weight: 750;
  line-height: 1;
}

.status-item {
  min-width: 0;
  text-align: center;
}

.status-value {
  color: #17202c;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.status-value.small {
  font-size: 28rpx;
}

.status-label {
  margin-top: 8rpx;
  color: #8a95a5;
  font-size: 23rpx;
}

.divider {
  width: 1rpx;
  height: 72rpx;
  background: #edf1f5;
}

.section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.section-title {
  margin-bottom: 22rpx;
  font-size: 31rpx;
  font-weight: 800;
}

.trust-row {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.trust-row:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  flex: 0 0 16rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #2f77ff;
}

.muted .dot {
  background: #aeb8c6;
}

.row-title {
  font-size: 29rpx;
  font-weight: 750;
  line-height: 1.35;
}

.row-text {
  margin-top: 8rpx;
  color: #6f7b8c;
  font-size: 25rpx;
  line-height: 1.6;
}

.version-entry {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #8a95a5;
  font-size: 24rpx;
  font-weight: 600;
}

.version-arrow {
  font-size: 34rpx;
  line-height: 1;
}
