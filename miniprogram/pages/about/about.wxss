page {
  min-height: 100vh;
  background: #f3f5f8;
  color: #17202c;
}

.page {
  min-height: 100vh;
  padding: 40rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  padding: 28rpx 0 34rpx;
  text-align: center;
}

.app-mark {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  border-radius: 8rpx;
  background: #17202c;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
  box-shadow: 0 18rpx 38rpx rgba(23, 32, 44, 0.18);
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.version {
  margin-top: 10rpx;
  color: #7b8797;
  font-size: 25rpx;
}

.section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(211, 218, 229, 0.9);
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(31, 42, 55, 0.06);
  box-sizing: border-box;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 31rpx;
  font-weight: 800;
}

.row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.row:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.row-title {
  font-size: 28rpx;
  font-weight: 750;
  line-height: 1.35;
}

.row-text {
  margin-top: 8rpx;
  color: #6f7b8c;
  font-size: 25rpx;
  line-height: 1.6;
}

.github-card {
  min-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #f7f9fc;
  box-sizing: border-box;
}

.github-text {
  min-width: 0;
  flex: 1;
  color: #17202c;
  font-size: 25rpx;
  line-height: 1.35;
  word-break: break-all;
}

.copy-text {
  flex: 0 0 auto;
  color: #2f77ff;
  font-size: 25rpx;
  font-weight: 700;
}
