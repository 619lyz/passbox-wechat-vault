page {
  min-height: 100vh;
  background: #f3f5f8;
  color: #17202c;
}

.page {
  min-height: 100vh;
  padding: 34rpx 30rpx calc(38rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 38rpx;
}

.hero-logo {
  width: 132rpx;
  height: 132rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 38rpx rgba(31, 42, 55, 0.12);
}

.hero-logo-image {
  display: block;
  overflow: hidden;
}

.logo-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 26rpx;
  max-width: 620rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
  word-break: break-word;
}

.detail-list,
.form-section {
  border: 1rpx solid rgba(211, 218, 229, 0.9);
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(31, 42, 55, 0.06);
}

.detail-row {
  min-height: 136rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 30rpx;
  border-bottom: 1rpx solid #edf1f5;
  box-sizing: border-box;
}

.detail-row:last-child {
  border-bottom: 0;
}

.password-row {
  display: block;
}

.password-row .row-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.password-row .text-button {
  width: 100%;
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.label,
.field-label {
  color: #8a95a5;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
}

.value {
  margin-top: 10rpx;
  color: #1c2735;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.password-value {
  letter-spacing: 3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.text-button {
  flex: 0 0 auto;
  width: 118rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #edf4ff;
  color: #226eea;
  font-size: 25rpx;
  font-weight: 650;
  line-height: 1;
}

.text-button:active,
.primary-button:active,
.secondary-button:active,
.danger-button:active,
.custom-logo-button:active,
.eye-button:active {
  transform: scale(0.985);
  opacity: 0.9;
}

.text-button::after,
.primary-button::after,
.secondary-button::after,
.danger-button::after,
.custom-logo-button::after,
.eye-button::after {
  border: 0;
}

.note {
  padding: 26rpx 30rpx;
}

.note-text {
  margin-top: 12rpx;
  color: #334155;
  font-size: 29rpx;
  line-height: 1.65;
  word-break: break-word;
}

.footer-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 28rpx;
}

.primary-button,
.secondary-button,
.danger-button {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.primary-button {
  background: #17202c;
  color: #ffffff;
  box-shadow: 0 16rpx 30rpx rgba(23, 32, 44, 0.16);
}

.secondary-button {
  background: #e9eef5;
  color: #1f2937;
}

.danger-button {
  background: #fff0f0;
  color: #d93025;
}

.form-section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.section-title {
  margin-bottom: 22rpx;
  color: #1c2735;
  font-size: 31rpx;
  font-weight: 800;
}

.logo-scroll {
  white-space: nowrap;
}

.logo-options {
  display: flex;
  gap: 20rpx;
}

.logo-option {
  width: 132rpx;
  flex: 0 0 132rpx;
  padding: 14rpx 10rpx 12rpx;
  border: 2rpx solid transparent;
  border-radius: 8rpx;
  text-align: center;
  box-sizing: border-box;
}

.logo-option-active {
  border-color: #2f77ff;
  background: #edf4ff;
}

.small {
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.logo-image {
  display: block;
  overflow: hidden;
  background: #f7f9fc;
}

.logo-name {
  margin-top: 11rpx;
  color: #566274;
  font-size: 22rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.custom-logo-button {
  width: 360rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 26rpx auto 0;
  padding: 0;
  border-radius: 8rpx;
  background: #eef2f7;
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1;
}

.custom-logo-plus {
  margin-right: 8rpx;
  color: #2f77ff;
  font-size: 30rpx;
  line-height: 1;
}

.custom-preview {
  display: block;
  width: 112rpx;
  height: 112rpx;
  margin: 20rpx auto 0;
  border-radius: 8rpx;
}

.field {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.field:first-child {
  padding-top: 0;
}

.field:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

input,
textarea {
  width: 100%;
  min-height: 56rpx;
  margin-top: 12rpx;
  color: #1c2735;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.45;
}

input::placeholder,
textarea::placeholder {
  color: #a5afbd;
}

textarea {
  min-height: 120rpx;
}

.password-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.password-input-row input {
  flex: 1;
  min-width: 0;
}

.eye-button {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #edf4ff;
}

.eye-icon {
  position: relative;
  width: 34rpx;
  height: 22rpx;
  border: 3rpx solid #2f77ff;
  border-radius: 50%;
  box-sizing: border-box;
}

.eye-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #2f77ff;
  transform: translate(-50%, -50%);
}

.eye-slash {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 42rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #2f77ff;
  transform: translate(-50%, -50%) rotate(-35deg);
}
