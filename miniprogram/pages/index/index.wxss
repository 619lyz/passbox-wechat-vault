page {
  min-height: 100vh;
  background: #f3f5f8;
  color: #17202c;
}

.page {
  min-height: 100vh;
  padding: 38rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.topbar > view:first-child {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 50rpx;
  font-weight: 800;
  line-height: 1.08;
}

.subtitle {
  margin-top: 10rpx;
  color: #7b8797;
  font-size: 25rpx;
}

.top-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.add-button,
.primary-button {
  height: 76rpx;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #17202c;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 650;
  line-height: 1;
  box-shadow: 0 14rpx 26rpx rgba(23, 32, 44, 0.16);
}

.add-button {
  flex: 0 0 132rpx;
  width: 132rpx;
  padding: 0;
}

.button-hover {
  opacity: 0.86;
}

.trust-strip {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid rgba(211, 218, 229, 0.9);
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(31, 42, 55, 0.05);
  box-sizing: border-box;
}

.bulk-strip {
  margin-bottom: 26rpx;
}

.bulk-button {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid rgba(211, 218, 229, 0.9);
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(31, 42, 55, 0.05);
  box-sizing: border-box;
}

.bulk-button-active {
  border-color: rgba(217, 48, 37, 0.2);
  background: #fffafa;
}

.bulk-title {
  color: #17202c;
  font-size: 27rpx;
  font-weight: 750;
  line-height: 1.3;
}

.bulk-text {
  margin-top: 5rpx;
  color: #7b8797;
  font-size: 23rpx;
  line-height: 1.35;
}

.bulk-action {
  flex: 0 0 auto;
  width: 96rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #17202c;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.bulk-action.danger {
  background: #fff0f0;
  color: #d93025;
}

.trust-title {
  color: #17202c;
  font-size: 27rpx;
  font-weight: 750;
  line-height: 1.3;
}

.trust-text {
  margin-top: 5rpx;
  color: #7b8797;
  font-size: 23rpx;
  line-height: 1.35;
}

.trust-arrow {
  flex: 0 0 auto;
  color: #9aa5b4;
  font-size: 42rpx;
  line-height: 1;
}

.add-icon {
  margin-right: 6rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1;
}

.add-text {
  font-size: 26rpx;
  line-height: 1;
  white-space: nowrap;
}

.add-button::after,
.primary-button::after {
  border: 0;
}

.bulk-action::after {
  border: 0;
}

.account-scroll {
  height: calc(100vh - 374rpx);
}

.account-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
  padding-bottom: 150rpx;
}

.account-card {
  position: relative;
  min-height: 242rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(211, 218, 229, 0.9);
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(31, 42, 55, 0.06);
  box-sizing: border-box;
}

.account-card-selected {
  border-color: #2f77ff;
  background: #f8fbff;
}

.account-card:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.select-mark {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #c7d0dc;
  border-radius: 50%;
  background: #ffffff;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  box-sizing: border-box;
}

.select-mark-active {
  border-color: #d93025;
  background: #d93025;
}

.logo-badge,
.logo-image,
.empty-logo {
  width: 92rpx;
  height: 92rpx;
  border-radius: 8rpx;
}

.logo-badge,
.empty-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
}

.logo-image {
  display: block;
  overflow: hidden;
  background: #f7f9fc;
}

.platform {
  margin-top: 26rpx;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.24;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.username {
  margin-top: 10rpx;
  color: #7b8797;
  font-size: 24rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-logo {
  background: #17202c;
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(23, 32, 44, 0.18);
}

.empty-title {
  margin-top: 30rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.empty-text {
  width: 520rpx;
  max-width: 100%;
  margin: 14rpx 0 36rpx;
  color: #7b8797;
  font-size: 26rpx;
  line-height: 1.7;
}

.batch-bar {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 10;
  height: 96rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  align-items: center;
  gap: 16rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(211, 218, 229, 0.9);
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(31, 42, 55, 0.14);
  box-sizing: border-box;
}

.batch-cancel,
.batch-delete {
  width: 100%;
  min-width: 0;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #fff0f0;
  color: #d93025;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.batch-cancel {
  background: #eef2f7;
  color: #17202c;
}
